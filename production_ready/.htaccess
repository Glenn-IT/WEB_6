<IfModule mod_rewrite.c>
    RewriteEngine On

    # Production server — domain is at root, so RewriteBase is /
    RewriteBase /

    # Redirect all requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]

</IfModule>
